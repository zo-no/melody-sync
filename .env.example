ANTHROPIC_API_KEY=your-api-key-here
# XFYUN online TTS (completion playback)
# XFYUN_APP_ID=your-app-id
# XFYUN_API_KEY=your-api-key
# XFYUN_API_SECRET=your-api-secret
# Optional tuning
# COMPLETION_TTS_PROVIDER=xfyun  # auto | xfyun | say
# COMPLETION_TTS_FALLBACK_TO_SAY=true
# XFYUN_VOICE=xiaoyan
# XFYUN_SPEED=50   # 0-100
# XFYUN_VOLUME=50  # 0-100
# XFYUN_PITCH=50   # 0-100
# CHAT_PORT=7760
# CHAT_BIND_HOST=127.0.0.1
# SESSION_EXPIRY=86400000
# Set to 0 for localhost mode (no HTTPS/Cloudflare)
# SECURE_COOKIES=0
